# ============================================
# Cascavel Security Framework — .gitignore
# RET Tecnologia | https://rettecnologia.org
# ============================================

# ── Python Bytecode ──────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyc
*.pyd

# ── Distribution / Packaging ─────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
*.whl
*.tar.gz
sdist/
wheels/
pip-wheel-metadata/

# ── Virtual Environments ─────────────────────
venv/
.venv/
env/
ENV/

# ── Environment Variables / Secrets ──────────
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets.yml
secrets.yaml
credentials.json

# ── IDE / Editor ─────────────────────────────
.vscode/
.idea/
.gemini/
*.sublime-project
*.sublime-workspace
*.code-workspace
.spyderproject
.spyproject
.ropeproject

# ── OS Generated ─────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Tool Caches ──────────────────────────────
.mypy_cache/
.ruff_cache/
.pytest_cache/
.tox/
.nox/
.hypothesis/
.pytype/
.pyre/
.pyre_configuration
stubs/

# ── Coverage ─────────────────────────────────
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover

# ── Logs ─────────────────────────────────────
*.log
pip-log.txt
pip-delete-this-directory.txt

# ── Temporary Files ──────────────────────────
*.tmp
*.temp
*.swp
*.swo
*~
*.bak

# ── Cascavel Runtime Outputs ─────────────────
exports/
reports/
nuclei-templates/
data/

# ── Wordlists (downloaded at runtime) ────────
wordlists/*.txt

# ── Dependencies (legacy) ────────────────────
.pipenv/
Pipfile.lock

# ── Jupyter Notebooks ────────────────────────
.ipynb_checkpoints/

# ── Docker ───────────────────────────────────
*.pid
docker-compose.override.yml

# ── Terraform / IaC (if used in plugins) ─────
.terraform/
*.tfstate
*.tfstate.*
*.tfvars

# ── Node (if frontend docs) ─────────────────
node_modules/
package-lock.json
yarn.lock
